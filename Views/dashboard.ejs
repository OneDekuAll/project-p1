<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - MessageBoard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f5f7fb; }
    .navbar { background: linear-gradient(90deg,#667eea,#764ba2) !important; }
    .topic-card { border:none; border-radius:12px; box-shadow:0 2px 12px rgba(0,0,0,.07); transition:transform .2s; }
    .topic-card:hover { transform:translateY(-2px); }
    .msg-item { background:#f8f9fa; border-radius:8px; }
  </style>
</head>
<body>
  <nav class="navbar navbar-dark navbar-expand-md mb-4">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/topics/dashboard">📋 MessageBoard</a>
      <div class="d-flex align-items-center gap-3">
        <a href="/topics/browse" class="btn btn-outline-light btn-sm">Browse Topics</a>
        <a href="/topics/new"    class="btn btn-light btn-sm">+ New Topic</a>
        <a href="/stats"         class="btn btn-outline-light btn-sm">📊 Stats</a>
        <span class="text-white-50">|</span>
        <span class="text-white">👤 <%= user.username %></span>
        <a href="/logout"        class="btn btn-outline-light btn-sm">Logout</a>
      </div>
    </div>
  </nav>
  <div class="container">
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <h4 class="mb-4 fw-semibold">Your Subscribed Topics</h4>
    <% if (topicsWithMessages.length === 0) { %>
      <div class="card topic-card p-5 text-center text-muted">
        <p class="mb-2 fs-5">You haven't subscribed to any topics yet.</p>
        <a href="/topics/browse" class="btn btn-primary">Browse Topics</a>
      </div>
    <% } else { %>
      <div class="row g-4">
        <% topicsWithMessages.forEach(({ topic, messages }) => { %>
          <div class="col-md-6 col-lg-4">
            <div class="card topic-card h-100">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h5 class="card-title mb-0">
                    <a href="/topics/<%= topic._id %>" class="text-decoration-none text-dark fw-bold"><%= topic.title %></a>
                  </h5>
                  <form method="POST" action="/topics/<%= topic._id %>/unsubscribe" class="ms-2">
                    <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-2"
                      onclick="return confirm('Unsubscribe from this topic?')">✕</button>
                  </form>
                </div>
                <% if (topic.description) { %>
                  <p class="text-muted small mb-3"><%= topic.description %></p>
                <% } %>
                <p class="text-muted small fw-semibold mb-1">Latest messages:</p>
                <% if (messages.length === 0) { %>
                  <p class="text-muted small fst-italic">No messages yet.</p>
                <% } else { %>
                  <% messages.forEach(msg => { %>
                    <div class="msg-item p-2 mb-2">
                      <div class="d-flex justify-content-between">
                        <span class="fw-semibold small">@<%= msg.author.username %></span>
                        <span class="text-muted" style="font-size:.7rem;"><%= new Date(msg.createdAt).toLocaleDateString() %></span>
                      </div>
                      <p class="mb-0 small"><%= msg.content.length > 80 ? msg.content.substring(0,80)+'…' : msg.content %></p>
                    </div>
                  <% }) %>
                <% } %>
              </div>
              <div class="card-footer bg-transparent border-0 pt-0">
                <a href="/topics/<%= topic._id %>" class="btn btn-primary btn-sm w-100">Open Topic →</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>