<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Topic - MessageBoard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background:#f5f7fb; }
    .navbar { background:linear-gradient(90deg,#667eea,#764ba2) !important; }
    .card { border:none; border-radius:14px; box-shadow:0 4px 24px rgba(0,0,0,.08); }
  </style>
</head>
<body>
  <nav class="navbar navbar-dark mb-4">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/topics/dashboard">📋 MessageBoard</a>
      <a href="/topics/dashboard" class="btn btn-outline-light btn-sm">← Dashboard</a>
    </div>
  </nav>
  <div class="container d-flex justify-content-center">
    <div class="card p-4 p-md-5 w-100" style="max-width:540px;">
      <h4 class="fw-bold mb-1">Create New Topic</h4>
      <p class="text-muted small mb-4">You'll be automatically subscribed to topics you create.</p>
      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <form method="POST" action="/topics/new">
        <div class="mb-3">
          <label class="form-label fw-semibold">Title *</label>
          <input type="text" name="title" class="form-control form-control-lg"
                 placeholder="e.g. JavaScript Tips" required maxlength="120">
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Description (optional)</label>
          <textarea name="description" class="form-control" rows="3"
                    placeholder="What is this topic about?" maxlength="500"></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-lg w-100">Create Topic</button>
      </form>
    </div>
  </div>
</body>
</html>