<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Statistics - MessageBoard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background:#f5f7fb; }
    .navbar { background:linear-gradient(90deg,#667eea,#764ba2) !important; }
    .bar { background:linear-gradient(90deg,#667eea,#764ba2); border-radius:4px; height:18px; min-width:4px; display:block; }
  </style>
</head>
<body>
  <nav class="navbar navbar-dark mb-4">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/topics/dashboard">📋 MessageBoard</a>
      <div class="d-flex gap-2">
        <a href="/topics/dashboard" class="btn btn-outline-light btn-sm">← Dashboard</a>
        <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
      </div>
    </div>
  </nav>
  <div class="container">
    <h4 class="fw-bold mb-1">📊 Topic Statistics</h4>
    <p class="text-muted mb-4">Number of times each topic has been accessed.</p>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <% if (topicsWithStats.length === 0) { %>
      <div class="alert alert-info">No topics found.</div>
    <% } else { %>
      <% const maxAccess = Math.max(...topicsWithStats.map(t => t.topic.accessCount), 1); %>
      <div class="card border-0 shadow-sm">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>#</th>
                <th>Topic</th>
                <th>Created By</th>
                <th>Messages</th>
                <th>Access Count</th>
                <th style="width:220px;">Chart</th>
              </tr>
            </thead>
            <tbody>
              <% topicsWithStats.forEach(({ topic, messageCount }, i) => { %>
                <% const barWidth = Math.round((topic.accessCount / maxAccess) * 200); %>
                <tr>
                  <td class="text-muted"><%= i+1 %></td>
                  <td><a href="/topics/<%= topic._id %>" class="fw-semibold text-decoration-none"><%= topic.title %></a></td>
                  <td class="text-muted">@<%= topic.createdBy.username %></td>
                  <td><%= messageCount %></td>
                  <td><strong><%= topic.accessCount %></strong></td>
                  <td><span class="bar" style="width:<%= barWidth %>px;"></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>
</body>
</html>